<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>إضافة قصة</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
<style>
body{
 font-family:'Cairo',sans-serif;
 background:#111;
 color:#fff;
 direction:rtl;
 padding:20px;
}
input,textarea,button{
 width:100%;
 margin:10px 0;
 padding:10px;
 font-family:'Cairo';
}
button{background:#FFD700;border:none;font-weight:bold;}
</style>
</head>
<body>

<h2>إضافة قصة جديدة</h2>

<input id="title" placeholder="عنوان القصة">
<input id="cardBg" placeholder="رابط خلفية صندوق القصة">
<input id="storyBg" placeholder="رابط خلفية نص القصة">
<textarea id="text" placeholder="نص القصة"></textarea>

<button onclick="addStory()">إضافة</button>

<script>
function addStory(){
 let stories = JSON.parse(localStorage.getItem("stories")) || [];
 stories.push({
  id: Date.now(),
  title: title.value,
  cardBg: cardBg.value,
  storyBg: storyBg.value,
  text: text.value
 });
 localStorage.setItem("stories", JSON.stringify(stories));
 alert("تمت الإضافة");
}
</script>

</body>
</html>
