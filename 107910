<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>نص القصة</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">

<style>
body{
  font-family:'Cairo',sans-serif;
  margin:0;
  padding:20px;
  direction:rtl;
  color:#fff;
  background-size:cover;
}
.story-box{
  background:rgba(0,0,0,.6);
  padding:20px;
  border-radius:15px;
}
</style>
</head>

<body>

<div class="story-box">
  <h2 id="title"></h2>
  <p id="text"></p>
</div>

<script>
const id=new URLSearchParams(location.search).get("id");

fetch("stories.json")
.then(r=>r.json())
.then(stories=>{
  const story=stories.find(s=>s.id==id);
  if(story){
    document.body.style.backgroundImage=`url(${story.storyBg})`;
    localStorage.setItem("chatBg",story.storyBg);
    localStorage.setItem("heroName",story.hero || "بطل القصة");
    title.innerText=story.title;
    text.innerText=story.text;
  }
});
</script>

</body>
</html>